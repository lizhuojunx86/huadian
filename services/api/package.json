{
  "name": "@huadian/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:reset": "tsx src/db-reset.ts",
    "schema:merge": "tsx scripts/merge-schema.ts",
    "schema:diff": "graphql-inspector diff git:main:services/api/src/schema/__snapshot__/schema.graphql src/schema/__snapshot__/schema.graphql",
    "codegen": "pnpm schema:merge && graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@graphql-tools/load-files": "^7.0.1",
    "@graphql-tools/merge": "^9.1.9",
    "@huadian/db-schema": "workspace:*",
    "@huadian/shared-types": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.9.0",
    "graphql-scalars": "^1.25.0",
    "graphql-yoga": "^5.10.6",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@graphql-codegen/add": "^6.0.1",
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/typescript": "^5.0.10",
    "@graphql-codegen/typescript-resolvers": "^5.1.8",
    "@graphql-inspector/cli": "^6.0.7",
    "@huadian/config-eslint": "workspace:*",
    "@huadian/config-typescript": "workspace:*",
    "@types/node": "^20.17.12",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.5"
  }
}
