{
  "name": "@huadian/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:reset": "tsx src/db-reset.ts"
  },
  "dependencies": {
    "@huadian/db-schema": "workspace:*",
    "@huadian/shared-types": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "graphql": "^16.9.0",
    "graphql-yoga": "^5.10.6",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@huadian/config-eslint": "workspace:*",
    "@huadian/config-typescript": "workspace:*",
    "@types/node": "^20.17.12",
    "drizzle-kit": "^0.30.2",
    "eslint": "^8.57.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
