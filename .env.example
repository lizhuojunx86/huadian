# ============================================================
# HuaDian — Environment Variables Template
# ============================================================
#
# Copy this file to .env.local (or .env) and fill in real values.
# This file is committed to git. NEVER put real secrets here.
# ============================================================

# ── Runtime ───────────────────────────────────────────────────
NODE_ENV=development

# ── Database (PostgreSQL 16) ──────────────────────────────────
DATABASE_URL=postgresql://huadian:huadian_dev@localhost:5432/huadian

# ── Cache (Redis 7) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── LLM (Anthropic) ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx-placeholder

# ── Embedding (ADR-005) ──────────────────────────────────────
EMBEDDING_MODEL=bge-large-zh-v1.5

# ── Observability — OpenTelemetry ─────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Observability — PostHog (product analytics) ──────────────
POSTHOG_API_KEY=phc_placeholder
POSTHOG_HOST=https://app.posthog.com

# ── Observability — Sentry (error monitoring) ────────────────
# Leave empty to disable Sentry in local dev
SENTRY_DSN=

# ── TraceGuard (pipeline QC runtime) ─────────────────────────
TRACEGUARD_POLICY_FILE=services/pipeline/config/traceguard_policy.yml

# ── API Server ────────────────────────────────────────────────
PORT=4000
