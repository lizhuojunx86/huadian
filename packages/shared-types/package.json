{
  "name": "@huadian/shared-types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema/*.json": "./schema/*.json"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "codegen": "tsx src/codegen.ts",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@huadian/config-eslint": "workspace:*",
    "@huadian/config-typescript": "workspace:*",
    "@types/node": "^20.17.12",
    "eslint": "^8.57.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "zod-to-json-schema": "^3.24.1"
  }
}
